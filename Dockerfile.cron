# Use node 18 slim as base image
FROM node:18-slim

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install production dependencies
RUN npm ci --only=production

# Copy application source code
COPY . .

# Set timezone env just in case (the scheduler uses Asia/Kolkata explicitly)
ENV TZ=Asia/Kolkata

# Start the cron scheduler
CMD ["node", "cronScheduler.js"]
